# ─── Application Config ───────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=super-secret-key-change-in-production-xyz9876543210
DEBUG=True

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///identity.db

# ─── JWT Settings ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-key-change-in-production-abc1234567890
JWT_ACCESS_TOKEN_EXPIRES=900       # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800   # 7 days

# ─── OTP / MFA ────────────────────────────────────────────────────────────────
OTP_ISSUER=DigitalIdentitySystem
OTP_VALIDITY_WINDOW=1

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=200 per day;50 per hour
RATE_LIMIT_LOGIN=10 per minute
RATE_LIMIT_REGISTER=5 per minute

# ─── Token Settings ───────────────────────────────────────────────────────────
API_TOKEN_EXPIRY_DAYS=30
